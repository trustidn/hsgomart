# Application
APP_PORT=8080
APP_ENV=development
# APP_ENV=production

# Database (user must exist in PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=hsmart_user
DB_PASSWORD=password
DB_NAME=hsmart_saas
# Must match DB_* above (used by migrate.sh)
DATABASE_URL=postgres://hsmart_user:password@localhost:5432/hsmart_saas?sslmode=disable

# JWT - REQUIRED in production (minimum 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=supersecret

# CORS (comma-separated origins, defaults to localhost for development)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend API URL (used by Vite build for production)
# In production, leave empty or unset (frontend is served by Go, same origin)
# VITE_API_URL=
