# Application
APP_PORT=8080
APP_ENV=development
# APP_ENV=production

# Database (user must exist in PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=hsmart_user
DB_PASSWORD=password
DB_NAME=hsmart_saas
# Must match DB_* above (used by migrate.sh)
DATABASE_URL=postgres://hsmart_user:password@localhost:5432/hsmart_saas?sslmode=disable

# JWT
JWT_SECRET=supersecret

# CORS (comma-separated origins, defaults to localhost for development)
# CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Frontend (used by Vite build)
# VITE_API_URL=https://api.yourdomain.com
